{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter Run (Android)",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "android"
      ],
      "problemMatcher": []
    },
    {
      "label": "Android App-Only Logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/mobile_app_logs.ps1"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
